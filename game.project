[bootstrap]
main_collection = /main/proxy.collectionc

[project]
title = Assassins Creed Templar Defense

[display]
variable_dt = 0
fullscreen = 0
update_frequency = 60
width = 1280
height = 720
vsync = 1
display_profiles = /builtins/render/default.display_profilesc

[script]
shared_state = 1

[physics]
debug = 0
use_fixed_timestep = 0
max_collisions = 128

[tilemap]
max_tile_count = 4096

[collectionfactory]
max_count = 128

